{% extends "layouts/base.html.twig" %}
{% block title %}{{ trans('reviews.show.page.title') }}{% endblock %}
{% block head %}  <style>
    :root {
      --ink: #171411;
      --paper: #fffdfa;
      --sand: #f4ebde;
      --line: #dbcbb7;
      --moss: #315845;
      --rust: #ba5a2d;
      --muted: #6f665c;
      --card: #f7efe3;
      --success: #21663a;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Georgia, serif;
      color: var(--ink);
      background: linear-gradient(180deg, #f8f3eb 0%, #efe5d8 100%);
    }
    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 40px 24px 64px;
    }
    a { color: var(--moss); }
    .hero, .card {
      background: rgba(255, 253, 250, 0.94);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(76, 62, 44, 0.06);
    }
    .hero { margin-bottom: 24px; }
    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.72rem;
      color: var(--rust);
      font-weight: 700;
    }
    h1 {
      margin: 8px 0 10px;
      font-size: clamp(2rem, 4vw, 3.2rem);
      letter-spacing: -0.04em;
    }
    p { line-height: 1.8; color: var(--muted); }
    .nav {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 16px;
    }
    .nav a {
      padding: 8px 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      text-decoration: none;
      background: rgba(255,255,255,0.7);
    }
    .status {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(49, 88, 69, 0.08);
      color: var(--moss);
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .notice {
      margin-top: 16px;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid rgba(33, 102, 58, 0.18);
      background: rgba(33, 102, 58, 0.08);
      color: var(--success);
      font-weight: 700;
    }
    .warning {
      margin-top: 16px;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid rgba(186, 90, 45, 0.28);
      background: rgba(186, 90, 45, 0.08);
      color: var(--ink);
    }
    .warning strong {
      display: block;
      margin-bottom: 6px;
      color: var(--rust);
    }
    .reopen {
      border: 1px solid rgba(186, 90, 45, 0.24);
      background: rgba(186, 90, 45, 0.06);
    }
    .layout {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 24px;
    }
    .stack {
      display: grid;
      gap: 18px;
    }
    h2 {
      margin: 0 0 12px;
      font-size: 1.3rem;
    }
    form {
      display: grid;
      gap: 12px;
    }
    label {
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--muted);
    }
    input, select, textarea, button {
      font: inherit;
    }
    input, select, textarea {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fff;
      color: var(--ink);
    }
    textarea {
      min-height: 110px;
      resize: vertical;
    }
    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    button {
      padding: 10px 14px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: var(--moss);
      color: #fff;
      cursor: pointer;
    }
    button.secondary {
      background: #fff;
      color: var(--moss);
    }
    .timeline {
      display: grid;
      gap: 14px;
    }
    .timeline-tools {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      margin-bottom: 12px;
      color: var(--muted);
      font-size: 0.92rem;
    }
    .entry {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      background: #fffefd;
    }
    .entry-header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: baseline;
      margin-bottom: 8px;
    }
    .entry-title {
      font-weight: 700;
    }
    .entry-meta {
      color: var(--muted);
      font-size: 0.88rem;
    }
    .entry-type {
      display: inline-block;
      margin-bottom: 8px;
      padding: 4px 10px;
      border-radius: 999px;
      background: var(--card);
      color: var(--rust);
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 700;
    }
    .confidence-list {
      display: grid;
      gap: 12px;
    }
    .confidence-item {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
      background: #fffefd;
    }
    .confidence-item.weak {
      border-color: rgba(186, 90, 45, 0.4);
      background: #fff8f2;
    }
    .checklist {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .checklist-item {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
      background: #fffefd;
    }
    .checklist-item strong {
      display: block;
      margin-bottom: 6px;
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
    }
    .confidence-item strong {
      display: block;
      margin-bottom: 8px;
    }
    .confidence-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 0.88rem;
    }
    .risk {
      color: var(--rust);
      font-weight: 700;
    }
    .empty {
      border: 1px dashed var(--line);
      border-radius: 14px;
      padding: 16px;
      background: #fffaf5;
      color: var(--muted);
    }
    @media (max-width: 960px) {
      .layout { grid-template-columns: 1fr; }
    }
  </style>
{% endblock %}
{% block body %}  <main>
    <section class="hero">
      <div class="eyebrow">Staff Review</div>
      <h1>{{ title }}</h1>
      <p>This cockpit is for Education Department and Economic Development review activity: capture comments, move the submission through revisions or approval, and preserve a visible audit trail.</p>
      <div class="status">{{ status }}</div>
      <div class="nav">
        <a href="/submissions">Back to submissions</a>
        <a href="/submissions/{{ submission_id }}">Structured data</a>
        <a href="/submissions/{{ submission_id }}/documents">Appendix documents</a>
        <a href="/submissions/{{ submission_id }}/exports">Exports</a>
      </div>
{%- if notice == 'comment_added' -%}<div class="notice">Review comment saved.</div>
{%- elseif notice == 'status_updated' -%}<div class="notice">Submission status updated and logged.</div>
{%- elseif notice == 'sent_back' -%}<div class="notice">Submission returned to intake and logged for follow-up.</div>
{%- elseif notice == 'appendix_reviewed' -%}<div class="notice">Appendix marked reviewed.</div>
{%- elseif notice == 'appendix_cleared' -%}<div class="notice">Appendix review state cleared.</div>
{%- elseif notice == 'appendix_reviewed_all' -%}<div class="notice">All appendices marked reviewed.</div>
{%- elseif notice == 'appendix_cleared_all' -%}<div class="notice">All appendix review states cleared.</div>
{%- elseif notice == 'appendix_note_added' -%}<div class="notice">Appendix review note saved.</div>
{%- elseif notice == 'appendix_note_cleared' -%}<div class="notice">Appendix review note cleared.</div>
{%- elseif notice == 'appendix_note_restored' -%}<div class="notice">Appendix review note restored from the latest saved version.</div>
{%- elseif notice == 'error_comment' -%}<div class="notice">Unable to save the comment. Check the form and try again.</div>
{%- elseif notice == 'error_status' -%}<div class="notice">Unable to update the status. Check the form and try again.</div>
{%- elseif notice == 'error_appendix_review_required' -%}<div class="notice">Approval, export, and submission require all six appendices to be staff-reviewed first.</div>
{%- elseif notice == 'error_send_back' -%}<div class="notice">A note is required to send the submission back to intake.</div>
{%- elseif notice == 'error_appendix_note' -%}<div class="notice">Unable to save the appendix review note.</div>
{%- elseif notice == 'error_appendix' -%}<div class="notice">Unable to update appendix review status.</div>
{%- endif -%}
{%- if workflow_warning != '' -%}<div class="warning"><strong>Approval warning</strong><div>Low-confidence intake fields are still open: {{ workflow_warning }}</div></div>
{%- endif -%}
{%- if appendix_review_warning is not null -%}<div class="warning"><strong>Review gate</strong><div>Approval, export, and submission are blocked until every appendix is staff-reviewed. Remaining: {{ appendix_review_warning }}.</div></div>
{%- endif -%}
    </section>
    <section class="layout">
      <div class="stack">
        <div class="card">
          <div class="eyebrow">Status Actions</div>
          <h2>Workflow</h2>
          <form method="post" action="/submissions/{{ submission_id }}/review/status">
            <div>
              <label for="status">New Status</label>
              <select id="status" name="status">
                <option value="ready_for_review">ready_for_review</option>
                <option value="revisions_requested">revisions_requested</option>
                <option value="approved">approved</option>
                <option value="exported">exported</option>
                <option value="submitted">submitted</option>
              </select>
            </div>
            <div>
              <label for="status_note">Note</label>
              <textarea id="status_note" name="note" placeholder="Explain why the status is changing or what should happen next."></textarea>
            </div>
            <div class="actions">
              <button type="submit">Update Status</button>
            </div>
          </form>
        </div>
        <div class="card reopen">
          <div class="eyebrow">Send Back</div>
          <h2>Return To Intake</h2>
          <p>Use this when staff review finds issues that require applicant edits or another intake pass. A note is required and becomes part of the audit trail.</p>
          <form method="post" action="/submissions/{{ submission_id }}/review/send-back">
            <div>
              <label for="send_back_note">Required Note</label>
              <textarea id="send_back_note" name="note" placeholder="Explain what needs to change before the submission can return to review."></textarea>
            </div>
            <div class="actions">
              <button type="submit">Send Back To Intake</button>
            </div>
          </form>
        </div>
        <div class="card">
          <div class="eyebrow">Reviewer Checkoff</div>
          <h2>Appendix Review Status</h2>
          <div class="actions">
            <form method="post" action="/submissions/{{ submission_id }}/review/appendix/review-all">
              <button type="submit">Mark All Reviewed</button>
            </form>
            <form method="post" action="/submissions/{{ submission_id }}/review/appendix/clear-all">
              <button type="submit" class="secondary">Clear All Reviews</button>
            </form>
          </div>
          <div class="checklist">
{%- for item in appendix_review -%}
<div class="checklist-item"><strong>{{ item.label }}</strong>{{ item.status }}<div class="entry-meta">{{ item.meta }}</div>
{%- if item.has_note -%}
<div class="annotation-value"><strong>Latest note</strong><div>{{ item.note_body_html|raw }}</div><div class="entry-meta">{{ item.note_meta }}</div></div>
{%- else -%}
<div class="entry-meta">No appendix-specific review note yet. {{ item.note_meta }}</div>
{%- endif -%}
<div class="actions">
{%- if item.reviewed -%}
<form method="post" action="/submissions/{{ item.submission_id }}/review/appendix/clear"><input type="hidden" name="appendix" value="{{ item.appendix }}"><button type="submit" class="secondary">Clear Review</button></form>
{%- else -%}
<form method="post" action="/submissions/{{ item.submission_id }}/review/appendix/review"><input type="hidden" name="appendix" value="{{ item.appendix }}"><button type="submit">Mark Reviewed</button></form>
{%- endif -%}
{%- if item.has_note -%}
<form method="post" action="/submissions/{{ item.submission_id }}/review/appendix/note/clear"><input type="hidden" name="appendix" value="{{ item.appendix }}"><button type="submit" class="secondary">Clear Note</button></form>
{%- endif -%}
{%- if item.show_restore -%}
<form method="post" action="/submissions/{{ item.submission_id }}/review/appendix/note/restore"><input type="hidden" name="appendix" value="{{ item.appendix }}"><button type="submit" class="secondary">Restore Last Note</button></form>
{%- endif -%}
</div><form method="post" action="/submissions/{{ item.submission_id }}/review/appendix/note"><input type="hidden" name="appendix" value="{{ item.appendix }}"><label for="appendix_note_{{ item.appendix }}">Review Note</label><textarea id="appendix_note_{{ item.appendix }}" name="comment" placeholder="Record appendix-specific feedback or signoff context.">{{ item.prefill_note }}</textarea><button type="submit" class="secondary">Save Note</button></form></div>
{%- endfor -%}
</div>
        </div>
        <div class="card">
          <div class="eyebrow">Appendix Checklist</div>
          <h2>Package Completeness</h2>
          {% include "components/shared/appendix-checklist.html.twig" with { completion_state: completion_state } %}
        </div>
        <div class="card">
          <div class="eyebrow">Field Confidence</div>
          <h2>Intake Risk</h2>
{%- if confidence_items is empty -%}
<div class="empty">No unresolved low-confidence intake fields are recorded right now.</div>
{%- else -%}
<div class="confidence-list">
{%- for item in confidence_items -%}
<article class="confidence-item weak"><strong>{{ item.path }}</strong><div class="confidence-meta"><span>confidence {{ item.confidence }}</span><span class="risk">follow-up needed</span><span>{{ item.updated_at }}</span></div><div>{{ item.note }}</div><p><a href="{{ item.data_link }}">Open in structured data</a> · <a href="{{ item.comment_link }}">Comment with prefilled field</a></p></article>
{%- endfor -%}
</div>
{%- endif -%}
        </div>
        <div class="card">
          <div class="eyebrow">Research Provenance</div>
          <h2>Research-Backed Updates</h2>
{%- if research_backed is empty -%}
<div class="empty">No active research-backed field updates are currently applied.</div>
{%- else -%}
<div class="confidence-list">
{%- for item in research_backed -%}
<article class="confidence-item"><strong>{{ item.target_path }}</strong><div class="confidence-meta"><span>provider: {{ item.source_provider }}</span><span>quality: {{ item.draft_quality }}</span><span>applied: {{ item.applied_at }}</span><span><a href="/submissions/{{ item.submission_id }}?edit_path={{ item.target_path_encoded }}">Inspect field</a></span></div><div>{{ item.source_query }}</div></article>
{%- endfor -%}
</div>
{%- endif -%}
        </div>
        <div class="card">
          <div class="eyebrow">Review Comment</div>
          <h2>Feedback</h2>
          <form method="post" action="/submissions/{{ submission_id }}/review/comment">
            <div>
              <label for="section_key">Section</label>
              <input id="section_key" name="section_key" value="{{ prefill_section }}" placeholder="appendix_m, workflow, exports, career_plan">
            </div>
            <div>
              <label for="field_path">Field Path</label>
              <input id="field_path" name="field_path" value="{{ prefill_field }}" placeholder="business.operations.launch_timeline">
            </div>
            <div>
              <label for="comment">Comment</label>
              <textarea id="comment" name="comment" placeholder="Record reviewer feedback, revision requests, or approval notes.">{{ prefill_comment }}</textarea>
            </div>
            <div class="actions">
              <button type="submit">Add Comment</button>
            </div>
          </form>
        </div>
      </div>
      <div class="card">
        <div class="eyebrow">Audit Trail</div>
        <h2>Review Timeline</h2>
        <div class="timeline-tools"><span>{{ timeline_mode }}</span><a href="{{ timeline_toggle_href }}">{{ timeline_toggle_label }}</a></div>
        <div class="timeline">
{%- if timeline_entries is empty -%}
<div class="empty">No staff review actions recorded yet.</div>
{%- else -%}
{%- for entry in timeline_entries -%}
{%- if entry.kind == 'appendix_group' -%}
<article class="entry"><div class="entry-type">{{ entry.action_type }}</div><div class="entry-header"><div class="entry-title">Appendix review activity ({{ entry.count }} entries)</div><div class="entry-meta">{{ entry.created_at != '' ? entry.created_at : '&nbsp;'|raw }}</div></div><div>
{%- for summary in entry.summaries -%}
<div><strong>{{ summary.title }}</strong>{% if summary.field_path != '' %} · {{ summary.field_path }}{% endif %}{% if summary.comment != '' %} : {{ summary.comment }}{% endif %}</div>
{%- endfor -%}
</div></article>
{%- elseif entry.kind == 'workflow_group' -%}
<article class="entry"><div class="entry-type">{{ entry.action_type }}</div><div class="entry-header"><div class="entry-title">Workflow activity ({{ entry.count }} entries)</div><div class="entry-meta">{{ entry.created_at != '' ? entry.created_at : '&nbsp;'|raw }}</div></div><div>
{%- for summary in entry.summaries -%}
<div><strong>{{ summary.title }}</strong> · {{ summary.action_type != '' ? summary.action_type : 'workflow' }}{% if summary.comment != '' %} : {{ summary.comment }}{% endif %}</div>
{%- endfor -%}
</div></article>
{%- elseif entry.kind == 'intake_group' -%}
<article class="entry"><div class="entry-type">{{ entry.action_type }}</div><div class="entry-header"><div class="entry-title">Intake activity ({{ entry.count }} entries)</div><div class="entry-meta">{{ entry.created_at != '' ? entry.created_at : '&nbsp;'|raw }}</div></div><div><strong>{{ entry.field_path != '' ? entry.field_path : 'intake' }}</strong>{% if entry.comment != '' %} : {{ entry.comment }}{% endif %}</div></article>
{%- else -%}
<article class="entry"><div class="entry-type">{{ entry.action_type }}</div><div class="entry-header"><div class="entry-title">{{ entry.title }}</div><div class="entry-meta">{{ entry.meta != '' ? entry.meta : '&nbsp;'|raw }}</div></div><div>{% if entry.body_is_raw %}{{ entry.body|raw }}{% else %}&nbsp;{% endif %}</div></article>
{%- endif -%}
{%- endfor -%}
{%- endif -%}
</div>
      </div>
    </section>
  </main>
{% endblock %}
