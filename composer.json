{
    "name": "waaseyaa/miikana",
    "description": "Miikana — schema-first proposal and funding pipeline app on the Waaseyaa framework",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "symfony/dotenv": "^8.0",
        "waaseyaa/bimaaji": "^0.1@dev",
        "waaseyaa/framework": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "config": {
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        }
    },
    "scripts": {
        "audit-site": "./bin/waaseyaa-audit-site",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "PHP_CLI_SERVER_WORKERS=4 bin/waaseyaa serve"
        ],
        "regen-lock": "@composer update 'waaseyaa/*' --no-plugins --no-install --no-scripts",
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa bin/waaseyaa-version bin/verify-deploy-rsync bin/waaseyaa-audit-site",
            "php bin/post-create-setup.php"
        ]
    },
    "extra": {
        "merge-plugin": {
            "include": [
                "composer.local.json"
            ],
            "prepend-repositories": true
        },
        "waaseyaa": {
            "providers": [
                "App\\Provider\\AppServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
